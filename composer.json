{
    "name": "andmarruda/authmodule",
    "description": "Invitation-based authentication module for Laravel",
    "type": "library",
    "require": {
        "php": "^8.1",
        "andmarruda/authorization-module": "dev-main",
        "illuminate/auth": "^10.0|^11.0|^12.0",
        "illuminate/mail": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/queue": "^10.0|^11.0|^12.0",
        "laravel/socialite": "^5.18"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "mockery/mockery": "^1.6"
    },
    "suggest": {
        "laravel/sanctum": "Optional API token authentication support for auth:sanctum routes."
    },
    "autoload": {
        "psr-4": {
            "Andmarruda\\AuthModule\\": ""
        },
        "files": [
            "Support/authorization_compat.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Andmarruda\\AuthModule\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Andmarruda\\AuthModule\\AuthModuleServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
}
